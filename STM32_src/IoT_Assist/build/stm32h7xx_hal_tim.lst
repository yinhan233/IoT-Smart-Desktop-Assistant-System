7871:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   * @param  TIMx to select the TIM peripheral
7872:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   * @param  TIM_ExtTRGPrescaler The external Trigger Prescaler.
7873:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *          This parameter can be one of the following values:
7874:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV1: ETRP Prescaler OFF.
7875:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV2: ETRP frequency divided by 2.
7876:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV4: ETRP frequency divided by 4.
7877:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *            @arg TIM_ETRPRESCALER_DIV8: ETRP frequency divided by 8.
7878:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   * @param  TIM_ExtTRGPolarity The external Trigger Polarity.
7879:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *          This parameter can be one of the following values:
7880:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *            @arg TIM_ETRPOLARITY_INVERTED: active low or falling edge active.
7881:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *            @arg TIM_ETRPOLARITY_NONINVERTED: active high or rising edge active.
7882:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   * @param  ExtTRGFilter External Trigger Filter.
7883:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   *          This parameter must be a value between 0x00 and 0x0F
7884:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   * @retval None
7885:Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_tim.c ****   */
