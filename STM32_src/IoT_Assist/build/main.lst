  91:Core/Src/main.c **** void OLED_Init(void) {
  92:Core/Src/main.c ****   HAL_Delay(100); // 等待屏幕上电稳定
  93:Core/Src/main.c **** 
  94:Core/Src/main.c ****   OLED_WriteCmd(0xAE); // 关闭显示
  95:Core/Src/main.c ****   OLED_WriteCmd(0xD5); // 设置时钟分频
  96:Core/Src/main.c ****   OLED_WriteCmd(0x80);
  97:Core/Src/main.c ****   OLED_WriteCmd(0xA8); // 设置多路复用率
  98:Core/Src/main.c ****   OLED_WriteCmd(0x3F);
  99:Core/Src/main.c ****   OLED_WriteCmd(0xD3); // 设置显示偏移
 100:Core/Src/main.c ****   OLED_WriteCmd(0x00);
 101:Core/Src/main.c ****   OLED_WriteCmd(0x40); // 设置起始行
 102:Core/Src/main.c ****   OLED_WriteCmd(0x8D); // 电荷泵设置
 103:Core/Src/main.c ****   OLED_WriteCmd(0x14); // 开启电荷泵
 104:Core/Src/main.c ****   OLED_WriteCmd(0x20); // 设置内存地址模式
 105:Core/Src/main.c ****   OLED_WriteCmd(0x02); // 页地址模式 (Page Addressing Mode)
 106:Core/Src/main.c ****   OLED_WriteCmd(0xA1); // 段重映射 (左右反转可改这里)
 107:Core/Src/main.c ****   OLED_WriteCmd(0xC8); // 扫描方向 (上下反转可改这里)
 108:Core/Src/main.c ****   OLED_WriteCmd(0xDA); // COM引脚配置
 109:Core/Src/main.c ****   OLED_WriteCmd(0x12);
 110:Core/Src/main.c ****   OLED_WriteCmd(0x81); // 对比度设置
 111:Core/Src/main.c ****   OLED_WriteCmd(0xCF);
 112:Core/Src/main.c ****   OLED_WriteCmd(0xD9); // 预充电周期
 113:Core/Src/main.c ****   OLED_WriteCmd(0xF1);
 114:Core/Src/main.c ****   OLED_WriteCmd(0xDB); // VCOMH电平
 115:Core/Src/main.c ****   OLED_WriteCmd(0x40);
 116:Core/Src/main.c ****   OLED_WriteCmd(0xA4); // 全屏显示开启 (A4正常, A5全亮)
 117:Core/Src/main.c ****   OLED_WriteCmd(0xA6); // 正常显示 (A7反色)
 118:Core/Src/main.c ****   OLED_WriteCmd(0xAF); // 开启显示
 119:Core/Src/main.c **** 
 120:Core/Src/main.c ****   // 清屏代码（可选，防止上电花屏）
 121:Core/Src/main.c ****   for(int i=0; i<8; i++) {
 122:Core/Src/main.c ****     OLED_WriteCmd(0xB0 + i); // 设置页地址 (0-7)
 123:Core/Src/main.c ****     OLED_WriteCmd(0x00);      // 设置列低地址
 124:Core/Src/main.c ****     OLED_WriteCmd(0x10);      // 设置列高地址
 125:Core/Src/main.c ****     for(int j=0; j<128; j++) OLED_WriteData(0x00);
 126:Core/Src/main.c ****   }
 127:Core/Src/main.c **** }
 128:Core/Src/main.c **** /* USER CODE END 0 */
 129:Core/Src/main.c **** 
