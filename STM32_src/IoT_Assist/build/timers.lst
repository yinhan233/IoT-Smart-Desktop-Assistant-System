 546:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****     static void prvReloadTimer( Timer_t * const pxTimer,
 547:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****                                 TickType_t xExpiredTime,
 548:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****                                 const TickType_t xTimeNow )
 549:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****     {
 550:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****         /* Insert the timer into the appropriate list for the next expiry time.
 551:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****          * If the next expiry time has already passed, advance the expiry time,
 552:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****          * call the callback function, and try again. */
 553:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****         while( prvInsertTimerInActiveList( pxTimer, ( xExpiredTime + pxTimer->xTimerPeriodInTicks )
 554:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****         {
 555:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****             /* Advance the expiry time. */
 556:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****             xExpiredTime += pxTimer->xTimerPeriodInTicks;
 557:Middlewares/Third_Party/FreeRTOS/Source/timers.c **** 
 558:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****             /* Call the timer callback. */
 559:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****             traceTIMER_EXPIRED( pxTimer );
 560:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****             pxTimer->pxCallbackFunction( ( TimerHandle_t ) pxTimer );
 561:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****         }
 562:Middlewares/Third_Party/FreeRTOS/Source/timers.c ****     }
