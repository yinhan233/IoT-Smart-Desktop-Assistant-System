1755:Drivers/CMSIS/Include/core_cm7.h **** */
1756:Drivers/CMSIS/Include/core_cm7.h **** #define _VAL2FLD(field, value)    (((uint32_t)(value) << field ## _Pos) & field ## _Msk)
1757:Drivers/CMSIS/Include/core_cm7.h **** 
1758:Drivers/CMSIS/Include/core_cm7.h **** /**
1759:Drivers/CMSIS/Include/core_cm7.h ****   \brief     Mask and shift a register value to extract a bit filed value.
