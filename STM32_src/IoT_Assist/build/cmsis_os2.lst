1763:Drivers/CMSIS/Include/core_cm7.h **** */
1764:Drivers/CMSIS/Include/core_cm7.h **** #define _FLD2VAL(field, value)    (((uint32_t)(value) & field ## _Msk) >> field ## _Pos)
